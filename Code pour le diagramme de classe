c@startuml
' Paramètres d'affichage pour la lisibilité
skinparam linetype ortho
left to right direction

abstract class Personne {
    + id : String
    + nom : String
    + prenom : String
    + dateNaissance : Date
    + paysOrigine : String
    + calculer_age() : int
}

class Sport {
    + nom : String
    + type : String
}

class Equipe {
    + id : String
    + nomLong : String
    + nomCourt : String
    + ville : String
    + pays : String
    + duree_match()
}

class Match {
    + id : String
    + date : Date
    + saison : String
    + score : String
    + stade_lieu : String
    + Vainqueur_match()
}

class Joueur {
    + taille : float
    + poids : float
    + position : String
    + mainDominante : String
    + calculer_statistiques()
}

class Entraineur {
    + role : String
    + anneesExperience : int
}

class Statistiques_match {
    + points_buts : int
    + fautes_penalites : int
    + temps_de_jeu : float
}

' --- Relations de Hiérarchie ---
Personne <|-- Joueur
Personne <|-- Entraineur

' --- Relations de Structure ---
Sport "1" -- "*" Match
Sport "1" -- "*" Equipe

' --- Relations d'Organisation ---
Equipe "1" *-- "*" Joueur
Equipe "1" *-- "0..*" Entraineur
Match "*" -- "2" Equipe

' --- Relations de Statistiques ---
Match "1" *-- "*" Statistiques_match
Joueur "1" -- "*" Statistiques_match
@enduml